<?xml version="1.0" encoding="UTF-8" ?>
<!-- EXP-5B: Seismic Excitation — Large Oil Storage Tank
     Tank:   10000 x 5000 x 8000 mm (L x B x H)
     Fill:   h=4800mm (60%)
     Motion: Sway at 0.3Hz (above resonance f1=0.266Hz), A=50mm
     Fluid:  Water (rho=998, proxy for light oil)
     dp=0.10m (coarse for large tank) -->
<case>
    <casedef>
        <constantsdef>
            <gravity x="0" y="0" z="-9.81" />
            <rhop0 value="998" />
            <rhopgradient value="2" />
            <hswl value="0" auto="true" />
            <gamma value="7" />
            <speedsystem value="0" auto="true" />
            <coefsound value="20" />
            <speedsound value="0" auto="true" />
            <coefh value="1.2" />
            <cflnumber value="0.2" />
        </constantsdef>
        <mkconfig boundcount="240" fluidcount="9" />
        <geometry>
            <definition dp="0.10" units_comment="metres (m)">
                <pointmin x="-1.0" y="-0.5" z="-1.0" />
                <pointmax x="11.0" y="5.5" z="9.0" />
            </definition>
            <commands>
                <mainlist>
                    <setshapemode>dp | bound</setshapemode>
                    <setdrawmode mode="full" />
                    <!-- Fluid: 10.0 x 5.0 x 4.8 m -->
                    <setmkfluid mk="0" />
                    <drawbox>
                        <boxfill>solid</boxfill>
                        <point x="0" y="0" z="0" />
                        <size x="10.0" y="5.0" z="4.8" />
                    </drawbox>
                    <!-- Tank walls: 10.0 x 5.0 x 8.0 m (no top) -->
                    <setmkbound mk="0" />
                    <drawbox>
                        <boxfill>bottom | left | right | front | back</boxfill>
                        <point x="0" y="0" z="0" />
                        <size x="10.0" y="5.0" z="8.0" />
                    </drawbox>
                    <shapeout file="Seismic" />
                </mainlist>
            </commands>
        </geometry>
        <motion>
            <objreal ref="0">
                <begin mov="1" start="0" />
                <!-- Seismic-like sway: f=0.3Hz (above resonance), A=50mm -->
                <mvrectsinu id="1" duration="20">
                    <freq x="0.3" y="0" z="0" units_comment="Hz" />
                    <ampl x="0.050" y="0" z="0" units_comment="metres" />
                    <phase x="0" y="0" z="0" units_comment="degrees" />
                </mvrectsinu>
            </objreal>
        </motion>
    </casedef>
    <execution>
        <special>
            <gauges>
                <default>
                    <savevtk value="false" />
                    <computedt value="0.05" comment="20Hz gauge output" />
                    <computetime start="0" end="20" />
                    <output value="false" />
                </default>
                <swl name="SWL_Left">
                    <point0 x="0.1" y="2.5" z="0.0" />
                    <point2 x="0.1" y="2.5" z="8.0" />
                    <pointdp value="0.5" />
                    <masslimit value="0.2" />
                </swl>
                <swl name="SWL_Right">
                    <point0 x="9.9" y="2.5" z="0.0" />
                    <point2 x="9.9" y="2.5" z="8.0" />
                    <pointdp value="0.5" />
                    <masslimit value="0.2" />
                </swl>
            </gauges>
        </special>
        <parameters>
            <parameter key="SavePosDouble" value="0" />
            <parameter key="StepAlgorithm" value="2" comment="2:Symplectic" />
            <parameter key="Kernel" value="2" comment="2:Wendland" />
            <parameter key="ViscoTreatment" value="1" comment="1:Artificial" />
            <parameter key="Visco" value="0.01" />
            <parameter key="ViscoBoundFactor" value="1" />
            <parameter key="DensityDT" value="2" comment="2:Fourtakas" />
            <parameter key="DensityDTvalue" value="0.1" />
            <parameter key="Shifting" value="0" />
            <parameter key="RigidAlgorithm" value="1" />
            <parameter key="DtIni" value="0.001" />
            <parameter key="DtMin" value="0.0001" />
            <parameter key="CoefDtMin" value="0.05" />
            <parameter key="TimeMax" value="20.0" units_comment="seconds" />
            <parameter key="TimeOut" value="0.1" units_comment="seconds (10Hz)" />
            <parameter key="PartsOutMax" value="1" />
            <parameter key="RhopOutMin" value="700" />
            <parameter key="RhopOutMax" value="1300" />
            <simulationdomain>
                <posmin x="default - 5%" y="default" z="default - 5%" />
                <posmax x="default + 5%" y="default" z="default + 40%" />
            </simulationdomain>
        </parameters>
    </execution>
</case>
