<?xml version="1.0" encoding="UTF-8" ?>
<!-- Zhao 2024 - Horizontal Cylindrical Tank (primitives)
     Tank:   D=1.0m (R=0.5m), L=3.0m, axis along X, center y=0, z=0.5
     Fill:   ~90% (simplified from 25.5% - partial fill in horizontal cylinder
             requires STL shell approach; this uses drawcylinder solid fill)
     Motion: Pitch about tank center axis, f=0.5496Hz, A=3deg
     Fluid:  Water (rho=998)
     dp=0.015m

     Boundary: solid cylinder R=0.50, then interior R=0.44 overwritten as fluid
     Shell thickness: 0.06m (4dp) - sufficient for DBC
     Upper 10% left as boundary to prevent overflow -->
<case>
    <casedef>
        <constantsdef>
            <gravity x="0" y="0" z="-9.81" />
            <rhop0 value="998" />
            <rhopgradient value="2" />
            <hswl value="0" auto="true" />
            <gamma value="7" />
            <speedsystem value="0" auto="true" />
            <coefsound value="20" />
            <speedsound value="0" auto="true" />
            <coefh value="1.2" />
            <cflnumber value="0.2" />
        </constantsdef>
        <mkconfig boundcount="240" fluidcount="9" />
        <geometry>
            <definition dp="0.015" units_comment="metres (m)">
                <pointmin x="-0.2" y="-0.7" z="-0.2" />
                <pointmax x="3.2" y="0.7" z="1.2" />
            </definition>
            <commands>
                <mainlist>
                    <setshapemode>dp | bound</setshapemode>
                    <setdrawmode mode="full" />
                    <!-- Step 1: Solid boundary cylinder R=0.50, with end caps extended -->
                    <setmkbound mk="0" />
                    <drawcylinder radius="0.50">
                        <point x="-0.03" y="0" z="0.5" />
                        <point x="3.03" y="0" z="0.5" />
                    </drawcylinder>
                    <!-- Step 2: Fluid cylinder R=0.44 (overwrites interior) -->
                    <setmkfluid mk="0" />
                    <drawcylinder radius="0.44">
                        <point x="0.0" y="0" z="0.5" />
                        <point x="3.0" y="0" z="0.5" />
                    </drawcylinder>
                    <!-- Step 3: Overwrite upper 10% back to boundary (sloshing cap) -->
                    <setmkbound mk="0" />
                    <drawbox>
                        <boxfill>solid</boxfill>
                        <point x="-0.03" y="-0.50" z="0.88" />
                        <size x="3.06" y="1.00" z="0.20" />
                    </drawbox>
                    <shapeout file="Zhao_HorizCyl" />
                </mainlist>
            </commands>
        </geometry>
        <motion>
            <objreal ref="0">
                <begin mov="1" start="0" />
                <!-- Pitch about tank longitudinal axis (X-axis through center z=0.5) -->
                <mvrotsinu id="1" duration="15" anglesunits="degrees">
                    <axisp1 x="0" y="0" z="0.5" />
                    <axisp2 x="3" y="0" z="0.5" />
                    <freq v="0.5496" units_comment="Hz" />
                    <ampl v="3.0" units_comment="degrees" />
                    <phase v="0" units_comment="degrees" />
                </mvrotsinu>
            </objreal>
        </motion>
    </casedef>
    <execution>
        <special>
            <gauges>
                <swl name="SWL_Left">
                    <point0 x="1.5" y="-0.48" z="0.0" />
                    <point2 x="1.5" y="-0.48" z="1.0" />
                    <pointdp value="0.5" />
                    <masslimit value="0.2" />
                    <savevtk value="false" />
                </swl>
                <swl name="SWL_Right">
                    <point0 x="1.5" y="0.48" z="0.0" />
                    <point2 x="1.5" y="0.48" z="1.0" />
                    <pointdp value="0.5" />
                    <masslimit value="0.2" />
                    <savevtk value="false" />
                </swl>
            </gauges>
        </special>
        <parameters>
            <parameter key="SavePosDouble" value="0" />
            <parameter key="StepAlgorithm" value="2" comment="2:Symplectic" />
            <parameter key="Kernel" value="2" comment="2:Wendland" />
            <parameter key="ViscoTreatment" value="1" comment="1:Artificial" />
            <parameter key="Visco" value="0.01" />
            <parameter key="ViscoBoundFactor" value="1" />
            <parameter key="DensityDT" value="2" comment="2:Fourtakas" />
            <parameter key="DensityDTvalue" value="0.1" />
            <parameter key="Shifting" value="0" />
            <parameter key="RigidAlgorithm" value="1" />
            <parameter key="DtIni" value="0.0002" />
            <parameter key="DtMin" value="0.00002" />
            <parameter key="CoefDtMin" value="0.05" />
            <parameter key="TimeMax" value="15.0" units_comment="seconds" />
            <parameter key="TimeOut" value="0.15" units_comment="seconds (101 frames)" />
            <parameter key="PartsOutMax" value="1" />
            <parameter key="RhopOutMin" value="700" />
            <parameter key="RhopOutMax" value="1300" />
            <simulationdomain>
                <posmin x="default - 10%" y="default - 15%" z="default - 10%" />
                <posmax x="default + 10%" y="default + 15%" z="default + 30%" />
            </simulationdomain>
        </parameters>
    </execution>
</case>
