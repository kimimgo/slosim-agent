<?xml version="1.0" encoding="UTF-8" ?>
<!-- ISOPE 2012 Sloshing Benchmark - LNG Mark III
     Tank:   946 x 118 x 670 mm (L x B x H)
     Fill:   90% → h=603mm
     Motion: Combined sway + pitch at f=0.6Hz
             Sway: A=20mm, Pitch: A=3 deg
     Center: Bottom center [0.473, 0.059, 0]
     Fluid:  Water (rho=998)
     dp=0.004m -->
<case>
    <casedef>
        <constantsdef>
            <gravity x="0" y="0" z="-9.81" />
            <rhop0 value="998" />
            <rhopgradient value="2" />
            <hswl value="0" auto="true" />
            <gamma value="7" />
            <speedsystem value="0" auto="true" />
            <coefsound value="20" />
            <speedsound value="0" auto="true" />
            <coefh value="1.2" />
            <cflnumber value="0.2" />
        </constantsdef>
        <mkconfig boundcount="240" fluidcount="9" />
        <geometry>
            <definition dp="0.006" units_comment="metres (m)">
                <pointmin x="-0.05" y="-0.02" z="-0.05" />
                <pointmax x="1.0" y="0.14" z="0.75" />
            </definition>
            <commands>
                <mainlist>
                    <setshapemode>dp | bound</setshapemode>
                    <setdrawmode mode="full" />
                    <!-- Fluid: 946 x 118 x 603 mm (90% fill) -->
                    <setmkfluid mk="0" />
                    <drawbox>
                        <boxfill>solid</boxfill>
                        <point x="0" y="0" z="0" />
                        <size x="0.946" y="0.118" z="0.603" />
                    </drawbox>
                    <!-- Tank walls: 946 x 118 x 670 mm (with top for roof impact) -->
                    <setmkbound mk="0" />
                    <drawbox>
                        <boxfill>bottom | left | right | front | back | top</boxfill>
                        <point x="0" y="0" z="0" />
                        <size x="0.946" y="0.118" z="0.670" />
                    </drawbox>
                    <shapeout file="ISOPE_LNG" />
                </mainlist>
            </commands>
        </geometry>
        <motion>
            <objreal ref="0">
                <begin mov="1" start="0" />
                <!-- Combined: Sway f=0.6Hz A=20mm + Pitch f=0.6Hz A=3deg -->
                <mvrectsinu id="1" duration="15">
                    <freq x="0.6" y="0" z="0" units_comment="Hz" />
                    <ampl x="0.020" y="0" z="0" units_comment="metres" />
                    <phase x="0" y="0" z="0" units_comment="degrees" />
                </mvrectsinu>
                <mvrotsinu id="2" duration="15" anglesunits="degrees">
                    <axisp1 x="0.473" y="0.059" z="0" />
                    <axisp2 x="0.473" y="-0.059" z="0" />
                    <freq v="0.6" units_comment="Hz" />
                    <ampl v="3.0" units_comment="degrees" />
                    <phase v="0" units_comment="degrees" />
                </mvrotsinu>
            </objreal>
        </motion>
    </casedef>
    <execution>
        <special>
            <gauges>
                <swl name="SWL_Left">
                    <point0 x="0.005" y="0.059" z="0.0" />
                    <point2 x="0.005" y="0.059" z="0.670" />
                    <pointdp value="0.5" />
                    <masslimit value="0.2" />
                    <savevtk value="false" />
                </swl>
                <swl name="SWL_Right">
                    <point0 x="0.941" y="0.059" z="0.0" />
                    <point2 x="0.941" y="0.059" z="0.670" />
                    <pointdp value="0.5" />
                    <masslimit value="0.2" />
                    <savevtk value="false" />
                </swl>
                <force name="Force_Roof">
                    <target mkbound="0" />
                    <savevtk value="false" />
                </force>
            </gauges>
        </special>
        <parameters>
            <parameter key="SavePosDouble" value="0" />
            <parameter key="StepAlgorithm" value="2" comment="2:Symplectic" />
            <parameter key="Kernel" value="2" comment="2:Wendland" />
            <parameter key="ViscoTreatment" value="1" comment="1:Artificial" />
            <parameter key="Visco" value="0.01" />
            <parameter key="ViscoBoundFactor" value="1" />
            <parameter key="DensityDT" value="2" comment="2:Fourtakas" />
            <parameter key="DensityDTvalue" value="0.1" />
            <parameter key="Shifting" value="0" />
            <parameter key="RigidAlgorithm" value="1" />
            <parameter key="DtIni" value="0.0001" />
            <parameter key="DtMin" value="0.00001" />
            <parameter key="CoefDtMin" value="0.05" />
            <parameter key="TimeMax" value="15.0" units_comment="seconds" />
            <parameter key="TimeOut" value="0.15" units_comment="seconds (101 frames)" />
            <parameter key="PartsOutMax" value="1" />
            <parameter key="RhopOutMin" value="700" />
            <parameter key="RhopOutMax" value="1300" />
            <simulationdomain>
                <posmin x="default - 15%" y="default" z="default - 10%" />
                <posmax x="default + 15%" y="default" z="default + 30%" />
            </simulationdomain>
        </parameters>
    </execution>
</case>
