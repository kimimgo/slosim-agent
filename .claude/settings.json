{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "cd /home/imgyu/workspace/02_active/slosim-agent && go vet ./... 2>&1 | head -20",
        "description": "go vet after every code edit"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": "echo \"$TOOL_INPUT\" | grep -qvE '(rm -rf|sudo|/mnt/storage)' || (echo 'BLOCKED: dangerous command' && exit 1)",
        "description": "Block dangerous bash commands"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ]
  }
}
