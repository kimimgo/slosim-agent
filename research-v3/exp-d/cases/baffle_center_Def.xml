<?xml version="1.0" encoding="UTF-8" ?>
<!-- EXP-D Baffle: Same as baseline + center vertical baffle
     Baffle: x=0.3m (center), height=0.14m (70% of fill), thickness=2*dp
     Expected: SWL amplitude reduction ~30-50% -->
<case>
    <casedef>
        <constantsdef>
            <gravity x="0" y="0" z="-9.81" />
            <rhop0 value="1000" />
            <rhopgradient value="2" />
            <hswl value="0" auto="true" />
            <gamma value="7" />
            <speedsystem value="0" auto="true" />
            <coefsound value="20" />
            <speedsound value="0" auto="true" />
            <coefh value="1.2" />
            <cflnumber value="0.2" />
        </constantsdef>
        <mkconfig boundcount="240" fluidcount="9" />
        <geometry>
            <definition dp="0.008" units_comment="metres (m)">
                <pointmin x="-0.05" y="-0.05" z="-0.05" />
                <pointmax x="0.65" y="0.35" z="0.5" />
            </definition>
            <commands>
                <mainlist>
                    <setshapemode>dp | bound</setshapemode>
                    <setdrawmode mode="full" />
                    <!-- Fluid (two halves separated by baffle) -->
                    <setmkfluid mk="0" />
                    <drawbox>
                        <boxfill>solid</boxfill>
                        <point x="0" y="0" z="0" />
                        <size x="0.6" y="0.3" z="0.2" />
                    </drawbox>
                    <!-- Tank walls -->
                    <setmkbound mk="0" />
                    <drawbox>
                        <boxfill>bottom | left | right | front | back</boxfill>
                        <point x="0" y="0" z="0" />
                        <size x="0.6" y="0.3" z="0.4" />
                    </drawbox>
                    <!-- Center vertical baffle (mk=10 for separate tracking) -->
                    <setmkbound mk="10" />
                    <drawbox>
                        <boxfill>solid</boxfill>
                        <point x="0.292" y="0" z="0" />
                        <size x="0.016" y="0.3" z="0.14" />
                    </drawbox>
                    <shapeout file="Tank_Baffle" />
                </mainlist>
            </commands>
        </geometry>
        <motion>
            <objreal ref="0">
                <begin mov="1" start="0" />
                <mvrectsinu id="1" duration="8" anglesunits="degrees">
                    <freq x="0.95" y="0" z="0" units_comment="Hz (near f1=1.01Hz)" />
                    <ampl x="0.01" y="0" z="0" units_comment="metres" />
                    <phase x="0" y="0" z="0" units_comment="degrees" />
                </mvrectsinu>
            </objreal>
        </motion>
    </casedef>
    <execution>
        <special>
            <gauges>
                <default>
                    <savevtkpart value="false" />
                    <computedt value="0.01" units_comment="100Hz gauge output" />
                    <computetime start="0" end="8" />
                    <output value="true" />
                    <outputdt value="0.01" units_comment="100Hz CSV" />
                </default>
                <swl name="SWL_Left">
                    <point0 x="0.01" y="0.15" z="0.0" />
                    <point2 x="0.01" y="0.15" z="0.4" />
                    <pointdp coefdp="0.5" />
                    <masslimit value="0.2" />
                </swl>
                <swl name="SWL_Right">
                    <point0 x="0.59" y="0.15" z="0.0" />
                    <point2 x="0.59" y="0.15" z="0.4" />
                    <pointdp coefdp="0.5" />
                    <masslimit value="0.2" />
                </swl>
            </gauges>
        </special>
        <parameters>
            <parameter key="SavePosDouble" value="0" />
            <parameter key="StepAlgorithm" value="2" comment="2:Symplectic" />
            <parameter key="Kernel" value="2" comment="2:Wendland" />
            <parameter key="ViscoTreatment" value="1" comment="1:Artificial" />
            <parameter key="Visco" value="0.01" />
            <parameter key="ViscoBoundFactor" value="1" />
            <parameter key="DensityDT" value="2" comment="2:Fourtakas" />
            <parameter key="DensityDTvalue" value="0.1" />
            <parameter key="Shifting" value="0" />
            <parameter key="RigidAlgorithm" value="1" />
            <parameter key="DtIni" value="0.0001" />
            <parameter key="DtMin" value="0.00001" />
            <parameter key="CoefDtMin" value="0.05" />
            <parameter key="TimeMax" value="8.0" />
            <parameter key="TimeOut" value="0.1" />
            <parameter key="PartsOutMax" value="1" />
            <parameter key="RhopOutMin" value="700" />
            <parameter key="RhopOutMax" value="1300" />
            <simulationdomain>
                <posmin x="default - 15%" y="default" z="default" />
                <posmax x="default + 15%" y="default" z="default + 50%" />
            </simulationdomain>
        </parameters>
    </execution>
</case>
