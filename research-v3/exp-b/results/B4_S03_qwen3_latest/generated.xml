<Simulation>
  <TimeStep>0.001</TimeStep>
  <Duration>10</Duration>
  <Fluid>
    <Density>1000</Density>
    <Viscosity>0.001</Viscosity>
  </Fluid>
  <Mesh>
    <Dimensions>0.6 0.3 0.65</Dimensions>
    <MeshSize>0.001</MeshSize>
